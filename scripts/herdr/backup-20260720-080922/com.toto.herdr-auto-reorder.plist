<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.toto.herdr-auto-reorder</string>
    <!-- reordena a sidebar de madrugada, SÓ se idle e desordenado (ver script) -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Users/lab/Claude/scripts/herdr-auto-reorder.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>37</integer>
    </dict>
    <!-- SEM RunAtLoad: nunca reinicia o server ao carregar; só no horário agendado -->
    <!-- SEM KeepAlive: é one-shot -->
    <key>ProcessType</key>
    <string>Background</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/lab/.local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/lab</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/lab/Library/Logs/herdr-auto-reorder.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/lab/Library/Logs/herdr-auto-reorder.log</string>
</dict>
</plist>
