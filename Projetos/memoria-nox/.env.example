# nox-mem — Environment variable template
#
# Usage:
#   cp .env.example .env
#   # Edit .env and fill in GEMINI_API_KEY at minimum
#   # Then: docker compose up
#
# All variables are optional except GEMINI_API_KEY (required for embeddings + KG extraction).
# For full reference: docs/CONFIGURATION.md
#
# SECURITY: Never commit .env to git. The .gitignore already excludes it.
# Run `grep -r "AIzaSy" .` before any commit to verify no key leaked.

# ── Core ──────────────────────────────────────────────────────────────────────
# TCP port the HTTP API listens on.
# Do NOT change to 18800 — Chrome's remote-debugger squats that port.
NOX_API_PORT=18802

# Path to the SQLite database file (full memory store).
# In Docker: /data is the mounted volume — keep this as-is.
# Outside Docker: use an absolute path or leave as ./nox-mem.db (relative to CWD).
NOX_DB_PATH=/data/nox-mem.db

# Root directory for all data files (KG snapshots, op-audit backups, temp artifacts).
# In Docker: /data is the mounted volume — keep this as-is.
NOX_MEM_DIR=/data

# Workspace root for multi-tenant / OpenClaw installations.
# Leave unset for standalone Docker usage.
# OPENCLAW_WORKSPACE=/root/.openclaw/workspace

# ── Providers — Gemini (default) ─────────────────────────────────────────────
# Required: Gemini API key for embeddings (3072-d) and KG extraction.
# Get one at: https://aistudio.google.com
GEMINI_API_KEY=

# Optional: OpenAI key — only needed if NOX_EMBEDDING_PROVIDER=openai or NOX_LLM_PROVIDER=openai
# OPENAI_API_KEY=

# Optional: Anthropic key — only needed if NOX_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# Optional: Voyage key — only needed if NOX_EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=

# ── Provider selection ────────────────────────────────────────────────────────
# Embedding provider: gemini | openai | voyage
# Switching providers changes all FUTURE embeddings. Run `nox-mem vectorize --force`
# after switching to rebuild the entire vector store from scratch.
NOX_EMBEDDING_PROVIDER=gemini

# Embedding model override. Leave commented to use provider default.
# Gemini default: gemini-embedding-001 (3072-d)
# NOX_EMBEDDING_MODEL=

# LLM provider for KG extraction, answer grounding, reflection: gemini | openai | anthropic
NOX_LLM_PROVIDER=gemini

# LLM model. NEVER change to gemini-2.5-flash (quota 3M/d exhausts quickly)
# or gemini-2.0-flash (deprecated, shutdown 2026-06-01).
NOX_LLM_MODEL=gemini/gemini-2.5-flash-lite

# Provider health check behavior on startup.
# 1 = throw if provider unreachable (default, recommended for prod).
# 0 = log warning and continue degraded (useful for first-run or CI without real keys).
NOX_PROVIDER_HEALTH_FAIL_FAST=1

# ── Search and ranking ────────────────────────────────────────────────────────
# Salience mode: shadow | active
# shadow = salience computed and exposed via /api/health but NOT applied to rankings.
# active = salience composes with RRF at query time.
# RULE: only flip to 'active' after ≥7 days shadow baseline + +1.0pp nDCG@10 eval gate.
NOX_SALIENCE_MODE=shadow

# Language-aware RRF weights (PT: dense 1.15×, FTS 0.85×; EN: balanced).
# Validated at +1.92pp on PT/EN mixed corpus (Wave E14). Leave on.
NOX_LANG_AWARE_RRF=1

# Persist query text in search_telemetry. 0 = off (default — privacy safe).
# Enable only for eval harness runs; never in shared or networked deployments.
NOX_SEARCH_LOG_TEXT=0

# ── Confidence field (L3) — defaults are safe, leave as-is ───────────────────
NOX_RANKING_CONFIDENCE=disabled
NOX_CONFIDENCE_OBSERVED=0.95
NOX_CONFIDENCE_INFERRED=0.65
NOX_CONFIDENCE_DERIVED=0.75
NOX_CONFIDENCE_GRAPHIFY=0.70
NOX_CONFIDENCE_USER_CANONICAL=1.00
NOX_CONFIDENCE_USER_REFUTED=0.05
NOX_CONFIDENCE_ACTIVE_FLOOR=0.30
NOX_CONFIDENCE_DECAY_HALFLIFE_DAYS=-1

# ── Conflict detection (L2) ───────────────────────────────────────────────────
NOX_CONFLICT_MODE=disabled
# Cron schedule for periodic conflict scanner. Only M H * * * format supported.
# NOX_CONFLICT_SCAN_CRON="0 3 * * *"

# ── L4 regex-first extraction ─────────────────────────────────────────────────
NOX_L4_REGEX_ENABLED=0
NOX_L4_SKIP_GEMINI=0
# DESTRUCTIVE: rewrites stored chunk text for slug renames. Leave off.
NOX_L4_AUTO_RENAME=0

# ── Real-time viewer (P5) ─────────────────────────────────────────────────────
# Show query text in the SSE viewer at /ui. 0 = redacted (default, safe).
# Enable only in local controlled sessions.
NOX_VIEWER_SHOW_QUERY=0

# Auth token for /api/* and viewer endpoints.
# REQUIRED if nox-mem is exposed beyond localhost (reverse proxy, public network).
# Generate: openssl rand -hex 32
# NOX_VIEWER_AUTH_TOKEN=

# ── Safety ────────────────────────────────────────────────────────────────────
# Allow destructive ops even if pre-op snapshot fails.
# EMERGENCY ONLY. Document the reason before enabling. See CLAUDE.md rule #6.
NOX_ALLOW_NO_SNAPSHOT=0
