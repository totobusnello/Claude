.DS_Store
node_modules/
*.log

# Local session scratch — logs, pids, temp state (not for version control)
.remember/
.claude/
.claire/   # Claude agent harness internal state (not for version control)

# Backup files from sed/edit operations — never commit
*.bak
*.bak2

# Graphify artifacts — generated by `graphify update <path>` (AST extraction).
# Source of truth vive em /root/vault/projetos/<repo>/graphify-out/ na VPS,
# ingestados no nox-mem como chunk_type=graph_node. Localmente é derivado.
graphify-out/

# Checkpoint snapshots — contain raw secrets (auth-profiles, claude credentials,
# cron payloads with keyring passwords). Live ONLY on VPS at /root/.openclaw/checkpoints/.
# NEVER commit, scp, or rsync to laptop.
checkpoints/
*.checkpoint
ckpt-snapshots/

# Local secret refs — ensure no .env-like or credentials file leaks via this repo
.env
.env.local
.env.*.local
*.credentials.json
gmeet-token.json
auth-profiles.json
claude-credentials.json

# VPS IP atual — local-only, muda com Hostinger floating-IP rebalance
.vps-current-ip

# Build artifacts — generated from src/; never commit
dist/

# SQLite databases — contain live corpus data, never commit
*.db
*.sqlite
*.db-wal
*.db-shm

# Python build artifacts — generated by pip install -e / build / pytest
*.egg-info/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.pyright/
build/

# Python virtualenvs (local dev, never commit)
venv/
.venv/
.omc/
