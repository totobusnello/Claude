# benchmark/ — gitignore policy
#
# Templates and configs are committed. Raw per-competitor data,
# intermediate JSONs, caches, and *rendered* outputs are NOT — they
# are reproducible artifacts that get regenerated by the harness.

# Generated rendered outputs (only ever produced by generate-comparison.ts
# with GATE_VERIFIED=1; commit explicitly when publishing).
COMPARISON.md
LOCOMO.md
LONGMEMEVAL.md
LATENCY.md

# Raw per-competitor results — gitignored by default. Commit explicitly
# (with `git add -f benchmark/results/...`) when a run becomes a
# published Lab finding or a gate input that backs a published comparison.
results/
!results/.gitkeep

# Scratch files
scratch/
*.scratch.json
*.scratch.md

# Adapter caches (if adapters cache competitor responses)
adapters/.cache/
adapters/**/.cache/

# Per-competitor scratch dirs (databases, indexes, large blobs)
work/
work-*/

# Editor cruft
.DS_Store
*.swp
*.swo

# Node modules in case adapters bring local deps
node_modules/

# Python adapter caches
__pycache__/
*.pyc
.venv/
.python-version

# Logs
*.log
logs/

# API key files (defence in depth — these should never be in this dir)
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
.credentials.json
