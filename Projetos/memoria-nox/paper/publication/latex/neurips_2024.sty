%% neurips_2024.sty — LOCAL STUB for draft compilation
%% Replaces the official NeurIPS 2024 style file.
%% Visual output will differ from the official NeurIPS template.
%% Purpose: allow `pdflatex main.tex` to succeed without the real .sty.
%%
%% Install the real file from:
%%   https://media.neurips.cc/Conferences/NeurIPS2024/Styles.zip
%% and place neurips_2024.sty alongside main.tex before camera-ready submission.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 stub]

%% ----------------------------------------------------------------
%% Option handling
%% ----------------------------------------------------------------
\newif\if@final
\DeclareOption{final}{\@finaltrue}
\DeclareOption{preprint}{\@finalfalse}
\DeclareOption{nonatbib}{}   % accepted, no-op in stub
\DeclareOption{longtitle}{}  % accepted, no-op in stub
\ProcessOptions\relax

%% ----------------------------------------------------------------
%% Required packages (all standard, no custom fonts)
%% ----------------------------------------------------------------
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{caption}
\RequirePackage{natbib}
\RequirePackage{xcolor}
\RequirePackage{ifthen}

%% ----------------------------------------------------------------
%% Page geometry — approximate NeurIPS single-column layout
%% ----------------------------------------------------------------
\geometry{
  letterpaper,
  top=1in,
  bottom=1in,
  left=1.25in,
  right=1.25in,
  headheight=14pt
}

%% ----------------------------------------------------------------
%% Fonts — use LaTeX defaults (no Times, no custom packages)
%% ----------------------------------------------------------------
%% The real NeurIPS .sty loads times/helvet; stub skips to avoid
%% "file not found" errors on minimal TeX installs.

%% ----------------------------------------------------------------
%% Section formatting
%% ----------------------------------------------------------------
\titleformat{\section}
  {\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}
  {\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}
  {\normalsize\itshape}{\thesubsubsection}{1em}{}

\titlespacing*{\section}{0pt}{1.5ex plus .5ex minus .2ex}{0.8ex plus .2ex}
\titlespacing*{\subsection}{0pt}{1.2ex plus .4ex minus .2ex}{0.5ex plus .1ex}

%% ----------------------------------------------------------------
%% Header / footer
%% ----------------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\small\thepage}
\if@final
  \fancyhead[C]{\small\textit{Preprint. Under review.}}
\fi

%% ----------------------------------------------------------------
%% Abstract environment
%% ----------------------------------------------------------------
\renewenvironment{abstract}{%
  \begin{center}%
    \bfseries Abstract%
  \end{center}%
  \begin{quotation}\small
}{%
  \end{quotation}%
}

%% ----------------------------------------------------------------
%% Bibliography — natbib unsrt (matches \bibliographystyle{unsrt})
%% ----------------------------------------------------------------
%% natbib already loaded above; no additional configuration needed.

%% ----------------------------------------------------------------
%% Figure / table captions
%% ----------------------------------------------------------------
\captionsetup{font=small, labelfont=bf, skip=4pt}

%% ----------------------------------------------------------------
%% Miscellaneous NeurIPS macros (stubs so \maketitle etc. work)
%% ----------------------------------------------------------------

%% \maketitle is provided by article class; no override needed.

%% Suppress "Submitted to NeurIPS" watermark logic from real .sty
%% (we simply do nothing here).

%% ----------------------------------------------------------------
%% Hyperref color defaults (real .sty sets these; mirror them)
%% ----------------------------------------------------------------
\@ifpackageloaded{hyperref}{%
  \hypersetup{
    colorlinks=true,
    linkcolor=black,
    citecolor=black,
    urlcolor=blue
  }%
}{}

\endinput
