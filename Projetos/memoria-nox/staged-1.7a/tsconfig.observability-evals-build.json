{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "./dist-observability-evals",
    "rootDir": ".",
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false
  },
  "include": [
    "edits/evals.ts",
    "edits/__tests__/observability-evals.test.ts",
    "_stubs/**/*.d.ts"
  ],
  "exclude": ["dist", "dist-observability-evals", "node_modules"]
}
