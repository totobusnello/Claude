{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "./dist-regex-extract",
    "rootDir": ".",
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false
  },
  "include": [
    "edits/regex-extract.ts",
    "edits/__tests__/regex-extract.test.ts",
    "_stubs/**/*.d.ts"
  ],
  "exclude": ["dist", "dist-regex-extract", "node_modules"]
}
