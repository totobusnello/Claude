{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "edits/lib/export-import.ts",
    "edits/cli/export-import-cli.ts",
    "tests/export-import-roundtrip.test.ts",
    "tests/export-import-v2-tier2.test.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
