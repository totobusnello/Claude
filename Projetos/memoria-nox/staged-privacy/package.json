{
  "name": "nox-mem-privacy-filter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Privacy filter staged patch — pre-storage redaction for nox-mem",
  "scripts": {
    "build": "tsc",
    "check:tests": "tsc -p tsconfig.tests.json --noEmit",
    "test": "tsc -p tsconfig.tests.json && node --test dist/privacy/__tests__/filter.test.js dist/privacy/__tests__/ingest-entity-privacy.test.js",
    "test:entity": "tsc -p tsconfig.tests.json && node --test dist/privacy/__tests__/ingest-entity-privacy.test.js",
    "test:watch": "node --watch --test dist/privacy/__tests__/filter.test.js dist/privacy/__tests__/ingest-entity-privacy.test.js"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
