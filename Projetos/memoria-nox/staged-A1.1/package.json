{
  "name": "nox-mem-privacy-br",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "A1.1 — Brazilian PII patterns (CPF/CNPJ/pix/CEP/RG) for nox-mem privacy filter",
  "scripts": {
    "build": "tsc",
    "check:tests": "tsc -p tsconfig.tests.json --noEmit",
    "test": "tsc -p tsconfig.tests.json && node --test dist/src/lib/privacy-br/__tests__/*.test.js",
    "test:patterns": "tsc -p tsconfig.tests.json && node --test dist/src/lib/privacy-br/__tests__/patterns.test.js",
    "test:validation": "tsc -p tsconfig.tests.json && node --test dist/src/lib/privacy-br/__tests__/validation.test.js",
    "eval:fp": "npm run build && node dist/src/eval/fp-rate.js"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
