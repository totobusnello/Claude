{
  "name": "nox-mem-answer-primitive",
  "version": "0.1.0-T1-T14",
  "private": true,
  "type": "module",
  "description": "P1 — Answer primitive staged patch (T1-T14): module skeleton + retrieval + prompt + provider + telemetry + CLI + HTTP + MCP + integration tests + E2E Gemini + docs + latency bench. Mock provider for CI. flash-lite locked per D41.",
  "scripts": {
    "build": "tsc",
    "check:tests": "tsc -p tsconfig.tests.json --noEmit",
    "test": "tsc -p tsconfig.tests.json && node --test dist/src/lib/answer/__tests__/*.test.js",
    "test:watch": "node --watch --test dist/src/lib/answer/__tests__/*.test.js",
    "bench:latency": "npm run build && node dist/benchmark/answer-latency.js",
    "test:e2e": "NOX_E2E_GEMINI=1 npm run build && node --test dist/src/lib/answer/__tests__/e2e-gemini.test.js"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^12.10.0",
    "typescript": "^5.4.0"
  }
}
