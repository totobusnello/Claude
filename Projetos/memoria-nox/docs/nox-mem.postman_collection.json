              "body": "{\n  \"results\": [\n    {\n      \"score\": 0.982,\n      \"source_file\": \"memory/lessons/salience-formula.md\",\n      \"snippet\": \"salience = recency × pain × importance — the pain coefficient amplifies high-severity incidents (pain=1.0) without suppressing low-pain background knowledge (pain=0.2 default).\",\n      \"chunk_type\": \"lesson\",\n      \"pain\": 1.0\n    },\n    {\n      \"score\": 0.871,\n      \"source_file\": \"memory/decisions/d48-pain-weighted.md\",\n      \"snippet\": \"D48 decision: pain weight 0.1 trivial → 1.0 prod-outage; default 0.2; multiplicative in salience but additive in display ranking.\",\n      \"chunk_type\": \"decision\",\n      \"pain\": 0.8\n    }\n  ],\n  \"query\": \"pain-weighted memory\",\n  \"latency_ms\": 940\n}"
            }
