        {
          "name": "Search hybrid",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/search?q=pain-weighted memory&limit=5",
              "host": ["{{base_url}}"],
              "path": ["api", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "pain-weighted memory",
                  "description": "Search query (required)"
                },
                {
                  "key": "limit",
                  "value": "5",
                  "description": "Maximum results to return (default 10)"
                },
                {
                  "key": "as_of",
                  "value": "",
                  "description": "ISO 8601 datetime — retrieve memory state as of this point in time (P3 temporal search)",
                  "disabled": true
                },
                {
                  "key": "changed_since",
                  "value": "",
                  "description": "ISO 8601 datetime — only return chunks modified after this date (P3)",
                  "disabled": true
                }
              ]
            },
            "description": "Hybrid search: FTS5 BM25 + Gemini semantic embeddings + RRF fusion. Returns ranked chunks with scores, source files, and snippets. Optional temporal parameters: `as_of` and `changed_since` (P3 wave)."
