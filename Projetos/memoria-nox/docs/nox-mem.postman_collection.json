        {
          "name": "Answer (flagship)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"q\": \"What is the salience formula?\",\n  \"limit\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/answer",
              "host": ["{{base_url}}"],
              "path": ["api", "answer"]
            },
            "description": "RAG-style question answering over the memory corpus. Returns a grounded answer with inline citation markers and a citations list. Gated by `NOX_ANSWER_ENABLED=1` on the server — returns 503 if disabled.\n\nBody fields:\n- `q` (required): the question to answer\n- `limit` (optional, default 5): max supporting chunks to retrieve\n- `session_id` (optional): session identifier for telemetry"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 503 (feature gate)', () => {",
                  "  pm.expect([200, 503]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Has answer field', () => {",
                  "    const b = pm.response.json();",
                  "    pm.expect(b).to.satisfy(r => r.answer || r.response || r.text);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "Answer response (demo)",
              "originalRequest": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\"q\": \"What is the salience formula?\", \"limit\": 5}"
                },
                "url": {
                  "raw": "{{base_url}}/api/answer",
                  "host": ["{{base_url}}"],
                  "path": ["api", "answer"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {"key": "Content-Type", "value": "application/json; charset=utf-8"}
              ],
              "body": "{\n  \"answer\": \"The salience formula is: salience = recency × pain × importance. Each factor is normalised to [0,1]. Pain defaults to 0.2 for routine memories and reaches 1.0 for prod-outage severity incidents [1]. Importance is derived from chunk type weights (lesson > decision > daily). Recency decays exponentially with configurable half-lives per chunk type [2].\",\n  \"chunks\": [\n    {\n      \"score\": 0.982,\n      \"source_file\": \"memory/lessons/salience-formula.md\",\n      \"snippet\": \"salience = recency × pain × importance\"\n    }\n  ],\n  \"latency_ms\": 1580\n}"
            }
          ]
        }
      ]
